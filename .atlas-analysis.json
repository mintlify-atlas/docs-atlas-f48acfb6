  "keyFeatures": [
    "Clean Architecture with distinct domain, application, and infrastructure layers",
    "CQRS pattern using MediatR for command and query separation",
    "Domain-Driven Design with aggregates, entities, and value objects",
    "JWT authentication via Keycloak integration",
    "Redis distributed caching for improved performance",
    "PostgreSQL database with Entity Framework Core",
    "Domain events for loose coupling between aggregates",
    "Health checks for monitoring service dependencies",
    "Validation using FluentValidation",
    "Logging with Serilog and Seq integration"
  ],
  "publicApiSurface": [
    "GET /api/apartments - Search available apartments",
    "GET /api/bookings/id - Get booking details (query param: id)",
    "POST /api/bookings - Reserve a new booking",
    "POST /api/users/register - Register a new user",
    "POST /api/users/login - Authenticate user",
    "GET /api/users/me - Get current user information",
    "POST /api/reviews - Add a review for completed booking",
    "GET /health - Health check endpoint"
  ]
